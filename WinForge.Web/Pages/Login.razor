@page "/login"
@page "/register"
@using MudBlazor
@inject IApiClient Api
@inject IAuthStateService Auth
@inject NavigationManager Nav

<PageTitle>WinForge — @(_isLogin ? "Sign In" : "Create Account")</PageTitle>

<MudGrid Justify="Justify.Center" Style="min-height:100vh;background:linear-gradient(135deg,#1E3A5F 0%,#2196F3 100%);">
    <MudItem xs="12" sm="8" md="5" lg="4" Style="display:flex;align-items:center;">
        <MudPaper Elevation="10" Class="pa-8 rounded-xl" Style="width:100%">

            <!-- Logo / Brand -->
            <MudStack AlignItems="AlignItems.Center" Class="mb-6">
                <MudIcon Icon="@Icons.Material.Filled.Window" Color="Color.Primary" Style="font-size:3rem;" />
                <MudText Typo="Typo.h4" Color="Color.Primary"><b>WinForge</b></MudText>
                <MudText Typo="Typo.body2" Color="Color.Secondary">
                    Window & Door Manufacturing Platform
                </MudText>
            </MudStack>

            <!-- Tab Switch -->
            <MudTabs Centered="true" @bind-ActivePanelIndex="_tabIndex" Class="mb-4">
                <MudTabPanel Text="Sign In" />
                <MudTabPanel Text="Register" />
            </MudTabs>

            @if (!string.IsNullOrEmpty(_errorMessage))
            {
                <MudAlert Severity="Severity.Error" Class="mb-4">@_errorMessage</MudAlert>
            }

            @if (_isLogin)
            {
                <MudTextField @bind-Value="_email" Label="Email" Variant="Variant.Outlined"
                              InputType="InputType.Email" Class="mb-3" FullWidth="true"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Email" />
                <MudTextField @bind-Value="_password" Label="Password" Variant="Variant.Outlined"
                              InputType="InputType.Password" Class="mb-4" FullWidth="true"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Lock" />
                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                           Size="Size.Large" OnClick="DoLogin" Disabled="_loading">
                    @if (_loading) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                    Sign In
                </MudButton>
            }
            else
            {
                <MudTextField @bind-Value="_companyName" Label="Company Name" Variant="Variant.Outlined"
                              Class="mb-3" FullWidth="true"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Business" />
                <MudTextField @bind-Value="_email" Label="Email" Variant="Variant.Outlined"
                              InputType="InputType.Email" Class="mb-3" FullWidth="true"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Email" />
                <MudTextField @bind-Value="_password" Label="Password (min 8 chars)" Variant="Variant.Outlined"
                              InputType="InputType.Password" Class="mb-3" FullWidth="true"
                              Adornment="Adornment.Start" AdornmentIcon="@Icons.Material.Filled.Lock" />
                <MudSelect @bind-Value="_country" Label="Country" Variant="Variant.Outlined"
                           Class="mb-4" FullWidth="true">
                    <MudSelectItem Value="@("Turkey")">🇹🇷 Turkey</MudSelectItem>
                    <MudSelectItem Value="@("Italy")">🇮🇹 Italy</MudSelectItem>
                    <MudSelectItem Value="@("France")">🇫🇷 France</MudSelectItem>
                    <MudSelectItem Value="@("Belgium")">🇧🇪 Belgium</MudSelectItem>
                    <MudSelectItem Value="@("Germany")">🇩🇪 Germany</MudSelectItem>
                    <MudSelectItem Value="@("Other")">🌍 Other</MudSelectItem>
                </MudSelect>
                <MudButton Variant="Variant.Filled" Color="Color.Primary" FullWidth="true"
                           Size="Size.Large" OnClick="DoRegister" Disabled="_loading">
                    @if (_loading) { <MudProgressCircular Size="Size.Small" Indeterminate="true" Class="mr-2" /> }
                    Create Account
                </MudButton>
            }
        </MudPaper>
    </MudItem>
</MudGrid>

@code {
    private int _tabIndex = 0;
    private bool _isLogin => _tabIndex == 0;

    private string _email = "";
    private string _password = "";
    private string _companyName = "";
    private string _country = "Turkey";
    private string _errorMessage = "";
    private bool _loading = false;
    private string _apiStatus = "";

    protected override async Task OnInitializedAsync()
    {
        if (Auth.IsLoggedIn) Nav.NavigateTo("/");
        if (Nav.Uri.Contains("register")) _tabIndex = 1;
    }

    private async Task DoLogin()
    {
        _loading = true; _errorMessage = "";
        try
        {
            var result = await Api.LoginAsync(new(_email, _password));
            if (result != null) { await Auth.LoginAsync(result); Nav.NavigateTo("/"); }
            else _errorMessage = "Invalid email or password. Check browser console for details.";
        }
        catch (Exception ex) { _errorMessage = $"Error: {ex.Message}"; }
        _loading = false;
    }

    private async Task DoRegister()
    {
        _loading = true; _errorMessage = "";
        try
        {
            var result = await Api.RegisterAsync(new(_companyName, _email, _password, null, _country));
            if (result != null) { await Auth.LoginAsync(result); Nav.NavigateTo("/"); }
            else _errorMessage = "Registration failed. Check browser console for details.";
        }
        catch (Exception ex) { _errorMessage = $"Error: {ex.Message}"; }
        _loading = false;
    }
}
